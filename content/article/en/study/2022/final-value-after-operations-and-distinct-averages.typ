= Personal Thoughts

== 1.

Thought Process
Original method: Use a hashmap to store elements in nums, each iteration finds the minimum and maximum values in the array, stores the average in a hashset, and removes the minimum and maximum values from the hashmap, repeating this process until the hashmap is empty.

Complexity: O(n^2)O(n)

Improved method: First sort the array nums, then use two pointers to traverse the minimum and maximum values.

Complexity: O(nlog(n))O(n)

```cpp
class Solution {
public:
    int distinctAverages(vector<int>& nums) {
        unordered_set<double> ust;
        unordered_map<int, int> ump;
        for (auto& x : nums) {
            ++ump[x];
        }
        int mx = INT_MIN, mi = INT_MAX;
        while (!ump.empty()) {
            mx = INT_MIN, mi = INT_MAX;
            for (auto& val : nums) {
                if (!ump.count(val)) {
                    continue;
                }
                mx = max(mx, val);
                mi = min(mi, val);
            }
            if (--ump[mx] == 0) {
                ump.erase(mx);
            }
            if (--ump[mi] == 0) {
                ump.erase(mi);
            }
            ust.insert(double(mx + mi) / 2.0);
        }
        return ust.size();
    }
};
```

