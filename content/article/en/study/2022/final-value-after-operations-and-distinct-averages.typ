= Personal Thoughts

== 1. Simulation

Initially set x=0, iterate through the string array operations. When encountering “++X" or “X++", increase x by 1; otherwise, decrease x by 1.

```cpp
class Solution {
public:
    int finalValueAfterOperations(vector<string>& operations) {
        int x = 0;
        for (auto &op : operations) {
            if (op == "X++" || op == "++X") {
                x++;
            } else {
                x--;
            }
        }
        return x;
    }
};
```

```cpp
class Solution {
public:
    int finalValueAfterOperations(vector<string>& operations) {
        int t = 0;
        for(auto &operation:operations){
            switch(operation[1]){
                case '+': t++;break;
                default: t--;break;
            }
        }
        return t;
    }
};
```

