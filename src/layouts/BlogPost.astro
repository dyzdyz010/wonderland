---
import type { CollectionEntry } from "astro:content";
import "../styles/global.css";
import "../styles/article.css";
import "../styles/comments.css";
import "../styles/code.css";
import FormattedDate from "../components/FormattedDate.astro";
import RootLayout from "./RootLayout.astro";
import Tags from "../components/Tags.astro";
import BackToTop from "../components/BackToTop.astro";
import Comments from "../components/comment/Comments.astro";
import Card from "../components/Card.astro";
import RenderedContent from "../components/content/RenderedContent.astro";
import { Icon } from "astro-icon/components";
import type { Locale } from "../i18n/config";
import { otherLocale, withLocale } from "../i18n/config";
import { t } from "../i18n/messages";
import { localizedAlternates, type AlternateLink } from "../i18n/seo";
import { articleNoticeBadges } from "../i18n/translation";

interface IdExt {
  id: string;
}

type Props = CollectionEntry<"blog">["data"] & (IdExt | { id: false }) & {
  locale: Locale;
  alternates?: AlternateLink[];
};

const { id, title, description, date, updatedDate, tags, locale, i18nKey, alternates, translationStatus, aiAuthored, ...rest } = Astro.props;
const m = t(locale);
const articlePath = id ? `/article/${i18nKey}/` : "/";
const pdfHref = id ? withLocale(locale, `/article/${i18nKey}.pdf`) : undefined;
const switchPath = id ? `/article/${i18nKey}/` : "/";
const pageAlternates = alternates ?? (id ? localizedAlternates(articlePath) : localizedAlternates("/"));
const commentSlug = i18nKey ?? id;
const articleNotices = articleNoticeBadges({ translationStatus, aiAuthored }, locale);
---

<RootLayout title={title} description={description} locale={locale} alternates={pageAlternates} switchPath={switchPath}>
  <div class="flex flex-col items-stretch gap-8">
    <Card>
      <article id={id || ""}>
        <div class="prose">
          <section class="title" aria-label="Title">
            <div class="annotation">
              <div class="date">
                <FormattedDate date={date} />
                {
                  updatedDate && (
                    <>
                      <span class="last-updated-on">
                        , {m.article.lastUpdated}{" "}
                        <FormattedDate date={updatedDate || date} />
                      </span>
                    </>
                  )
                }
              </div>
              <div class="inline-flex items-center gap-2">
                <a
                  href={withLocale(otherLocale(locale), switchPath)}
                  class="inline-flex items-center gap-1.5 self-center rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium leading-none text-[var(--color-gray)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                >
                  <Icon name="mdi:translate" class="h-4 w-4" aria-hidden="true" />
                  <span>{m.article.switchLanguage}</span>
                </a>
                {
                  pdfHref && (
                    <a
                      href={pdfHref}
                      class="inline-flex items-center gap-1.5 self-center rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium leading-none text-[var(--color-gray)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                      target="_blank"
                      rel="noopener"
                    >
                      <Icon name="mdi:file-pdf-box" class="h-4 w-4" aria-hidden="true" />
                      <span>{m.article.downloadPdf}</span>
                    </a>
                  )
                }
              </div>
            </div>
            <h1>{title}</h1>
            {
              articleNotices.length > 0 && (
                <div class="mt-3 mb-6 flex flex-wrap items-center gap-2">
                  {articleNotices.map((notice) => (
                    <div class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-1 text-xs font-medium text-[var(--color-gray)]" aria-label={notice.label}>
                      <Icon name={notice.icon} class="h-4 w-4" aria-hidden="true" />
                      <span>{notice.label}</span>
                    </div>
                  ))}
                </div>
              )
            }
            <hr />
          </section>
          <RenderedContent variant="article">
            <slot />
          </RenderedContent>
          <Tags tags={tags ?? []} class="mt-10" />
        </div>
      </article>
    </Card>
    <Card>
      <Comments server:defer postSlug={commentSlug} class="mt-2" />
    </Card>
  </div>
  <BackToTop />
</RootLayout>
