---
import CommentItem from "./CommentItem.astro";
import { listApprovedComments } from "../../features/comments/db";

const { postSlug, class: className, ...props } = Astro.props;

let comments = [];
let unavailable = false;

try {
  comments = await listApprovedComments(Astro.locals.runtime?.env ?? {}, postSlug);
} catch (error) {
  unavailable = true;
  console.warn("Comments unavailable", error);
}
---

<div class="comments-list flex flex-col gap-4" {...props}>
  {
    unavailable ? (
      <p class="text-sm text-[var(--color-gray)]">Comments are temporarily unavailable.</p>
    ) : comments.length > 0 ? (
      comments.map((comment) => <CommentItem comment={comment} />)
    ) : (
      <p class="text-sm text-[var(--color-gray)]">No comments yet.</p>
    )
  }
</div>
