---
import type { CollectionEntry } from "astro:content";
import type { HTMLAttributes } from "astro/types";
import Card from "../Card.astro";
import { withLocale } from "../../i18n/config";
import { localizedEntrySlug } from "../../i18n/content";
import { normalizeTags } from "../../utils/tags";

type BlogEntry = CollectionEntry<"blog">;

// 组件 props 的类型
interface Props extends HTMLAttributes<"div"> {
  posts: BlogEntry[]; // ← 明确标注
  class?: string; // （可选）允许传 class
}

const { posts, class: className, ...props }: Props = Astro.props;

const years = posts.map((post) => post.data.date.getFullYear());
const uniqueYears = [...new Set(years)];
---

<div class="flex flex-col items-stretch gap-8">
  {
    uniqueYears.map((year) => {
      const postsInYear = posts.filter(
        (post) => post.data.date.getFullYear() === year
      );
      return (
        <Card class={className} {...props} key={year}>
          <div class="meta mb-3 flex items-center justify-between gap-3 text-base">
            <div class="flex items-center gap-3">
              <div class="text-[16px] text-[var(--color-default)]">{year}年</div>
              <div class="w-2 h-2 bg-[var(--color-border)] rounded-full" />
              <div class="text-sm text-[var(--color-gray)]">
                {postsInYear.length}篇文章
              </div>
            </div>
          </div>
          {postsInYear.map((post) => {
            const tags = normalizeTags(post.data.tags ?? []);
            const month =
              post.data.date.getMonth() + 1 < 10
                ? `0${post.data.date.getMonth() + 1}`
                : post.data.date.getMonth() + 1;
            const day =
              post.data.date.getDate() < 10
                ? `0${post.data.date.getDate()}`
                : post.data.date.getDate();
            const date = `${month}-${day}`;
            return (
              <a
                href={withLocale(post.data.lang, `/article/${localizedEntrySlug(post)}`)}
                class="group flex min-h-10 items-center gap-3 py-3 text-[var(--color-default)] no-underline! transition-all hover:no-underline!"
              >
                <span class="w-[44px] shrink-0 text-right font-mono text-sm font-medium text-[var(--color-gray)]">
                  {date}
                </span>
                <div class="relative flex h-2 w-2 items-center justify-center">
                  <div class="bg-[var(--color-gray)] group-hover:bg-[var(--color-accent)] h-[5px] w-[5px] rounded-full transition-all duration-300 group-hover:h-4" />
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    fill="none"
                    class="absolute bottom-4"
                  >
                    <path
                      stroke="currentColor" class="text-[var(--color-gray)]"
                      stroke-linecap="round"
                      d="M8 .5v3M8 6.5v3M8 12.5v3"
                    />
                  </svg>
                </div>
                <div class="min-w-0 flex-1 truncate text-sm font-medium text-[var(--color-default)] transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--color-accent)]">
                  {post.data.title}
                </div>
                {tags.length > 0 && (
                  <div class="ml-auto hidden max-w-[42%] shrink-0 flex-wrap items-center justify-end gap-2 text-sm text-[var(--color-gray)] lg:flex">
                    {tags.map((tag) => (
                      <span class="whitespace-nowrap">#{tag.label}</span>
                    ))}
                  </div>
                )}
              </a>
            );
          })}
        </Card>
      );
    })
  }
</div>
