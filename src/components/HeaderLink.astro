---
import type { HTMLAttributes } from "astro/types";
import { isNavigationLinkActive, type NavigationActiveMatch } from "../utils/navigation";

type Props = HTMLAttributes<"a"> & {
  activeMatch?: NavigationActiveMatch;
};

const { href, class: className, activeMatch = "prefix", ...props } = Astro.props;
const rawHref = href?.toString().replace(import.meta.env.BASE_URL, "") ?? "";
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const isActive = isNavigationLinkActive(rawHref, pathname, activeMatch);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
  <slot />
</a>
<style>
  a {
    display: inline-block;
    text-decoration: none;
  }
  a.active {
    font-weight: bolder;
    text-decoration: underline;
  }
</style>
