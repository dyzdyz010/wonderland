---
import { Icon } from "astro-icon/components";
import { SITE_AUTHOR } from "../consts";

const today = new Date();
---

<footer class="flex flex-col items-center px-4 py-4 text-center mt-20 gap-2">
  <p>&copy; 2025-{today.getFullYear()} {SITE_AUTHOR}. All rights reserved.</p>
  <p class="text-sm text-[var(--color-gray)]">
    Inspired by
    <a
      href="https://www.yysuni.com/blog"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--color-gray)] underline-offset-4 transition-colors hover:text-[var(--color-accent)] hover:underline"
    >YYsuni</a>
  </p>
  <div class="social-links">
    <a class="icon" href="https://github.com/dyzdyz010" target="_blank">
      <span class="sr-only">Go to My GitHub's Profile</span>
      <Icon name="mdi:github" class="w-8 h-8" />
    </a>
    <a class="icon" href={`/rss.xml`} target="_blank">
      <span class="sr-only">RSS/Atom feeds</span>
      <Icon name="mdi:rss" class="w-8 h-8" />
    </a>
  </div>
</footer>
