---
import { getCollection } from "astro:content";
import { SITE_TITLE } from "../consts";
import Card from "./Card.astro";
import PostList from "./post/PostList.astro";
import ContentSurface from "./content/ContentSurface.astro";
import { type Locale, withLocale } from "../i18n/config";
import { findLocalizedPage, postsForLocale, sortPostsNewestFirst } from "../i18n/content";
import { t } from "../i18n/messages";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = t(locale);
const pages = await getCollection("page");
const about = findLocalizedPage(pages, locale, "about");
const posts = sortPostsNewestFirst(postsForLocale(await getCollection("blog"), locale)).slice(0, 10);
---

<section aria-label="Prelude" class="mb-10">
  <h1 class="italic font-bold">{SITE_TITLE}</h1>
  {about && (
    <Card>
      <ContentSurface entry={about} variant="embed" />
    </Card>
  )}
</section>
<section class="flex flex-col gap-4">
  <h2>{m.pages.recentPostsTitle}</h2>
  <PostList posts={posts} />
  <a class="self-start text-sm font-semibold text-[var(--color-gray)] hover:text-[var(--color-default-hover)]" href={withLocale(locale, "/article")}>
    {m.pages.morePosts}<span aria-hidden="true" class="ml-1 font-bold">→</span>
  </a>
</section>
