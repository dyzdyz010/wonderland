---
import RootLayout from "../../../layouts/RootLayout.astro";
import { SITE_TITLE } from "../../../consts";
import { getCollection } from "astro:content";
import PostList from "../../../components/post/PostList.astro";
import Tags from "../../../components/Tags.astro";
import {
  buildTagSummaries,
  getTagDefinitionById,
  postHasTag,
} from "../../../utils/tags";
import { assertLocale, withLocale } from "../../../i18n/config";
import { postsForLocale, sortPostsNewestFirst } from "../../../i18n/content";
import { t } from "../../../i18n/messages";
import { localizedAlternates } from "../../../i18n/seo";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return ["zh", "en"].flatMap((localeValue) => {
    const locale = assertLocale(localeValue);
    const tags = buildTagSummaries(postsForLocale(posts, locale));

    return [
      { params: { locale, tag: undefined } },
      ...tags.map(({ id }) => ({ params: { locale, tag: id } })),
    ];
  });
}

const locale = assertLocale(Astro.params.locale);
const m = t(locale);
const allPosts = sortPostsNewestFirst(postsForLocale(await getCollection("blog"), locale));

const rawParam = Astro.params.tag;
const activeTagId = Array.isArray(rawParam)
  ? (rawParam[0] ?? null)
  : (rawParam ?? null);

const tagSummaries = buildTagSummaries(allPosts);

const filteredPosts = activeTagId
  ? allPosts.filter((post) => postHasTag(post, activeTagId))
  : allPosts;

const tagSummary = activeTagId
  ? tagSummaries.find((entry) => entry.id === activeTagId)
  : undefined;
const tagDefinition = activeTagId
  ? getTagDefinitionById(activeTagId)
  : undefined;
const tagLabel = activeTagId
  ? (tagSummary?.label ?? tagDefinition?.label ?? activeTagId)
  : m.pages.tagAll;
const tagCount = activeTagId
  ? (tagSummary?.count ?? filteredPosts.length)
  : filteredPosts.length;

const pageTitle = activeTagId
  ? `#${tagLabel} · ${SITE_TITLE}`
  : `${m.pages.tagsTitle} · ${SITE_TITLE}`;
const pageDescription = activeTagId
  ? m.pages.tagCount(tagCount, tagLabel)
  : m.pages.tagsDescription;
const heading = activeTagId ? `${tagLabel}` : m.pages.tagsTitle;
const subtitle = activeTagId
  ? m.pages.tagCount(tagCount, tagLabel)
  : m.pages.tagPick;
const switchPath = activeTagId ? `/tag/${activeTagId}` : "/tag";
---

<RootLayout title={pageTitle} description={pageDescription} locale={locale} alternates={localizedAlternates(switchPath)} switchPath={switchPath}>
  <section class="flex flex-col gap-6">
    <header class="flex flex-col gap-2">
      <h1 class="text-3xl font-bold">
        <span class="pr-1 text-[var(--color-accent)] underline">#</span>
        {heading}
      </h1>
      <p class="text-[var(--color-gray)]">{subtitle}</p>
    </header>

    <Tags
      tags={tagSummaries}
      showAll
      activeTag={activeTagId}
      allLabel={m.pages.tagAll}
      allCount={allPosts.length}
      basePath={withLocale(locale, "/tag")}
    />

    {
      filteredPosts.length ? (
        <PostList posts={filteredPosts} />
      ) : (
        <p class="italic text-[var(--color-gray)]">
          {m.pages.tagEmpty}
        </p>
      )
    }
  </section>
</RootLayout>
