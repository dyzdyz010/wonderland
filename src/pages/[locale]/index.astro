---
import RootLayout from "../../layouts/RootLayout.astro";
import HomePage from "../../components/HomePage.astro";
import { SITE_TITLE } from "../../consts";
import { assertLocale } from "../../i18n/config";
import { t } from "../../i18n/messages";
import { localizedAlternates } from "../../i18n/seo";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "zh" } }, { params: { locale: "en" } }];
}

const locale = assertLocale(Astro.params.locale);
const m = t(locale);
---

<RootLayout title={SITE_TITLE} description={m.siteDescription} locale={locale} alternates={localizedAlternates("/")} switchPath="/">
  <HomePage locale={locale} />
</RootLayout>
